{
   "mcpServers": {
    "chrome-devtools": {
      "args": [
        "chrome-devtools-mcp@latest"
      ],
      "command": "npx",
      "env": {},
      "type": "stdio"
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp@latest",
        "--api-key",
        "${CONTEXT7_API_KEY}"
      ],
      "command": "npx",
      "env": {},
      "type": "stdio"
    },
    "dart": {
      "args": [
        "mcp-server"
      ],
      "command": "dart",
      "env": {},
      "type": "stdio"
    },
    "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx",
      "env": {},
      "type": "stdio"
    },
    "sequential-thinking": {
      "args": [
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx",
      "env": {},
      "type": "stdio"
    },
    "web-reader": {
      "headers": {
        "Authorization": "Bearer ${Z_AI_API_KEY}"
      },
      "type": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp"
    },
    "web-search-prime": {
      "headers": {
        "Authorization": "Bearer ${Z_AI_API_KEY}"
      },
      "type": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp"
    },
    "zai-mcp-server": {
      "args": [
        "-y",
        "@z_ai/mcp-server"
      ],
      "command": "npx",
      "env": {
        "Z_AI_API_KEY": "${Z_AI_API_KEY}"
      },
      "type": "stdio"
    },
    "zread": {
      "headers": {
        "Authorization": "Bearer ${Z_AI_API_KEY}"
      },
      "type": "http",
      "url": "https://open.bigmodel.cn/api/mcp/zread/mcp"
    }
  }
}